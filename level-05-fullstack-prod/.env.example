# .env.example - 第5关：环境变量模板
# 生产环境必须修改以下值！
# 复制此文件为 .env 或 .env.prod 后使用

# ===== 数据库配置 =====
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_pass           # ⚠️ 生产环境请使用强密码！
POSTGRES_DB=app_db
DATABASE_URL=postgres://app_user:app_pass@postgres:5432/app_db

# ===== 应用配置 =====
NODE_ENV=production
PORT=3000

# ===== Nginx 配置 =====
NGINX_PORT=80

# ===== JWT 密钥（如有） =====
# JWT_SECRET=your-super-secret-key-here

# ===== Docker Compose 的项目名称 =====
# COMPOSE_PROJECT_NAME=lvl5
